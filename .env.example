# API key de OpenRouter (server-side, NO lleva prefijo VITE_ para que nunca
# se incluya en el bundle del navegador). Se usa en api/chat.js.
OPENROUTER_API_KEY=

# Opcional: pisa el modelo gratuito por defecto definido en api/chat.js.
# Verificar modelos disponibles y con soporte de "tools" en https://openrouter.ai/models
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
