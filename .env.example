# API key de OpenRouter (server-side, NO lleva prefijo VITE_ para que nunca
# se incluya en el bundle del navegador). Se usa en api/chat.js.
OPENROUTER_API_KEY=

# Opcional: pisa el modelo por defecto ("openrouter/free", un router
# automático entre modelos gratuitos con soporte de tool calling).
# Ver alternativas en https://openrouter.ai/models?supported_parameters=tools
OPENROUTER_MODEL=openrouter/free
